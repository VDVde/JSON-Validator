# Docker build context exclusions
# Prevents sensitive files from being included in the image

# Version control
.git/
.gitignore

# IDE/Editor
.idea/
.vscode/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.env
.venv
venv/
env/
*.egg-info/
.eggs/
pip-log.txt

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build artifacts
dist/
build/
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Documentation
docs/_build/

# Docker
Dockerfile*
docker-compose*.yml
.docker/

# Security: Sensitive files
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets
*.secret
credentials.json
service-account.json

# Local development
.DS_Store
Thumbs.db
*.log
tmp/
temp/

# Test fixtures (may contain sensitive test data)
tests/fixtures/
